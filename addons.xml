<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.video.alkoflix" version="2.0.14" name="alkoFlix" provider-name="Les alKODIques">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests"/>
            <import addon="script.module.addon.signals"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="resources/lib/router.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.service" library="resources/lib/service.py"/>
        <extension point="xbmc.addon.metadata">
            <reuselanguageinvoker>false</reuselanguageinvoker>
            <license>GNU GENERAL PUBLIC LICENSE. Version 3, 29 June 2007</license>
            <summary lang="en">Everything you love to watch, whenever you want.</summary>
            <summary lang="fr">Tout ce que vous aimez, quand vous le voulez.</summary>
            <description lang="en">French video streaming add-on. Requires a subscription to a compatible debrid service.</description>
            <description lang="fr">Extension vidéo de streaming en français. Nécessite un abonnement à un service de débridage compatible.</description>
            <news lang="en">Version 2.0.14: fixes alkoPastes userdata restore after settings cleanup hardening.</news>
            <news lang="fr">Version 2.0.14 : correction de la restauration des sauvegardes alkoPastes après le nettoyage des paramètres.</news>
            <assets>
                <icon>plugin.video.alkoflix/icon.png</icon>
                <fanart>plugin.video.alkoflix/fanart.jpg</fanart>
                <clearlogo>plugin.video.alkoflix/clearlogo.png</clearlogo>
            </assets>
        </extension>
    </addon>
    <addon id="repository.alkoflix" name="Dépôt alkoFlix" version="1.0" provider-name="Les alKODIques">
        <requires>
            <import addon="xbmc.addon" version="12.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="Dépôt alkoFlix">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/alkODIque/repository.alkoflix/master/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/alkODIque/repository.alkoflix/master/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/alkODIque/repository.alkoflix/master/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="fr">Dépôt officiel alkoFlix pour Kodi.</summary>
            <summary lang="en">Official alkoFlix repository for Kodi.</summary>
            <description lang="fr">Installe et met à jour automatiquement alkoFlix et les extensions Kodi associées.</description>
            <description lang="en">Install and automatically update alkoFlix and related Kodi add-ons.</description>
            <license>GPL-3.0</license>
            <news lang="fr">Première version du dépôt officiel alkoFlix.</news>
            <news lang="en">First official alkoFlix repository release.</news>
            <platform>all</platform>
            <assets>
                <icon>repository.alkoflix/icon.png</icon>
                <fanart>repository.alkoflix/fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
</addons>
